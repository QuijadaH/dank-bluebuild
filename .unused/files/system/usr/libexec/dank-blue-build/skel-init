#!/usr/bin/env bash

set -euo pipefail

VERSION="v1"

[ -e "/var/lib/dank-blue-build/skel-init/$VERSION-done" ] && exit 0

SKEL="/etc/skel"

# iterate users
awk -F: '$3 >= 1000 && $3 < 65534 { print $1 ":" $6 }' /etc/passwd |
while IFS=: read -r user home; do
    [[ -d "$home" ]] || continue

    # already initialized -> skip user entirely
    if [[ -f "$home/.local/state/dank-blue-build/skel-init/$VERSION-done" ]]; then
        continue
    fi

    echo "Bootc skel init: $user"

    # walk every skel entry recursively
    find "$SKEL" -mindepth 1 -print0 |
    while IFS= read -r -d '' src; do
        rel="${src#"$SKEL"/}"
        dst="$home/$rel"

        # create directories only
        if [[ -d "$src" ]]; then
            mkdir -p "$dst"
            chown "$user:$user" "$dst"
            continue
        fi

        # backup only the leaf being replaced
        if [[ -e "$dst" || -L "$dst" ]]; then
            backup="$dst.skel-init-$VERSION.bak"
            mv "$dst" "$backup"
        fi

        mkdir -p "$(dirname "$dst")"

        cp -a "$src" "$dst"
        chown -h "$user:$user" "$dst"
    done
done

mkdir -p /var/lib/dank-blue-build/skel-init
touch /var/lib/dank-blue-build/skel-init/$VERSION-done
