[Unit]
Description=Skel initialization for existing users (bootc-managed)
After=systemd-user-sessions.service
Before=greetd.service
ConditionPathExists=!/var/lib/dank-bluebuild/skel-init/v1-done

[Service]
Type=oneshot
ExecStart=/usr/libexec/dank-bluebuild/skel-init/run

[Install]
WantedBy=multi-user.target      