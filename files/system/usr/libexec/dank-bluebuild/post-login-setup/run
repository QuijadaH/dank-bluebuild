#!/usr/bin/env bash

set -euo pipefail

disable_autostart() {
    echo "Disabling autostart..."
    echo "Creating the disable flag for autostart..."

    if [ -f "/var/lib/dank-bluebuild/post-login-setup/auto.disabled" ]; then
        echo "The disable flag already exists."
    else
        if ! sudo touch /var/lib/dank-bluebuild/post-login-setup/auto.disabled; then
            echo "Could not create the disable flag." >&2
            echo "Failed to disable autostart." >&2
            echo "You can manually disable the autostart by creating the file '/var/lib/dank-bluebuild/post-login-setup/auto.disabled'."
            return 1
        fi

        echo "Successfully created the disable flag."
        echo "Autostart has been disabled."
    fi
    
    return 0
}

autostart_prompt() {
    if [ "$EUID" -eq 0 ]; then
        while true; do
            echo "Allow this script to automatically run again on next login to retry/complete post-login setup? (Y/n)"
            read -r response

            case "$response" in
                [Yy]* | "" )
                    if [ -f "/var/lib/dank-bluebuild/post-login-setup/auto.disabled" ]; then
                        echo "Removing the disable flag..."
                        if ! sudo rm /var/lib/dank-bluebuild/post-login-setup/auto.disabled; then
                            echo "Failed to remove the disable flag." >&2; 
                            echo "The post-login setup will not autostart on next login."
                            break
                        fi
                        
                        echo "Successfully removed the disable flag."
                    fi

                    echo "The post-login setup will autostart again on next login."
                    break
                    ;;
                [Nn]* )
                    disable_autostart
                    break
                    ;;
                * )
                    echo "Invalid response. Please enter y or n."
                    ;;
            esac
        done
    else  
        echo "You can manually disable the autostart by creating the file '/var/lib/dank-bluebuild/post-login-setup/auto.disabled'."
    fi

    echo "You can manually start the setup again by executing 'post-login-setup' in the terminal with or without sudo."
}

echo "### DANK BLUE BUILD SETUP ###"
echo "You can review the contents of this setup in '/usr/libexec/dank-bluebuild/post-login-setup/' before you proceed."

if [ "$EUID" -ne 0 ]; then
    echo "This setup requires sudo privileges."
    echo "Requesting sudo privileges... (Press Ctrl+C to cancel)"

    if ! sudo -v &> /dev/null; then
        echo "Failed to obtain sudo privileges." >&2
        autostart_prompt
        exit 1
    fi

    echo "Sudo privileges granted."
else
    read -r -p "Press Enter to continue or Ctrl+C to cancel."
fi

sudo_keepalive() {
    while sleep 60; do
        sudo -n true || exit
    done
}
sudo_keepalive &
SUDO_LOOP_PID=$!

LOGPIPE="/tmp/logpipe.$$"
mkfifo "$LOGPIPE"

# shellcheck disable=SC2329
cleanup() {
    kill "$SUDO_LOOP_PID" 2>/dev/null || true
    sudo -K || true
    rm -rf "$LOGPIPE"
}
trap cleanup EXIT

declare -a FAILED_SCRIPTS=()

# shellcheck disable=SC2329
on_interrupt() {
    trap - INT TERM

    echo "Setup interrupted." >&2
    autostart_prompt || true

    exit 130
}
trap on_interrupt INT TERM

STATE_PATH="/var/lib/dank-bluebuild/post-login-setup/script.d"
sudo mkdir -p "$STATE_PATH"

SCRIPT_DIR="/usr/libexec/dank-bluebuild/post-login-setup/script.d"
shopt -s nullglob
SCRIPTS=( "$SCRIPT_DIR"/* )

LOG_FILE="/var/lib/dank-bluebuild/post-login-setup/run.log"
# shellcheck disable=SC2024
sudo tee -a "$LOG_FILE" < "$LOGPIPE" &
exec >"$LOGPIPE" 2>&1

if [ "${#SCRIPTS[@]}" -ne 0 ]; then
    for script in "${SCRIPTS[@]}"; do
        [[ -f "$script" && -x "$script" ]] || continue

        if [ -f "$STATE_PATH/$(basename "$script").completed" ]; then
            echo "Script '$script' already completed. Skipping..."
            continue
        fi

        echo "Executing '$script'..."
        if ! sudo "$script"; then
            FAILED_SCRIPTS+=("$script")
        else
            sudo touch "$STATE_PATH/$(basename "$script").completed"
        fi
    done
fi

if [ ${#FAILED_SCRIPTS[@]} -ne 0 ]; then
    echo "The following scripts failed during setup:" >&2
    for script in "${FAILED_SCRIPTS[@]}"; do
        echo "  - $script" >&2
    done

    echo "Please review the errors for the failed scripts." 
    [ -f "/var/lib/dank-bluebuild/post-login-setup/log" ] && echo "View the log file '/var/lib/dank-bluebuild/post-login-setup/run.log'." >&2
    autostart_prompt
    exit 1
else
    disable_autostart
    echo "All scripts executed successfully. "
    echo "Setup completed."
    exit 0
fi