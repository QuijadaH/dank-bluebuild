#!/usr/bin/env bash

set -euo pipefail

# shellcheck disable=SC2329
on_interrupt() {
    trap - INT TERM
    echo "Script interrupted." >&2
    exit 130
}
trap on_interrupt INT TERM

echo "Syncing DankGreeter to user theme..."

failed() {
    echo "Failed to sync DankGreeter." >&2
    exit 1
}

if [ "$EUID" -ne 0 ]; then
    env DMS_PRIVESC=sudo dms greeter sync || failed
else
    sudo -u "$SUDO_USER" env DMS_PRIVESC=sudo dms greeter sync || failed
fi

echo "Successfully synced DankGreeter."
exit 0