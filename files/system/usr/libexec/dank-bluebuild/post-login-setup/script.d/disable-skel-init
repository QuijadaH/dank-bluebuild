#!/usr/bin/env bash

set -euo pipefail

# shellcheck disable=SC2329
on_interrupt() {
    trap - INT TERM
    echo "Script interrupted." >&2
    exit 130
}
trap on_interrupt INT TERM

echo "Disabling skel-init.service..."

failed() {
    echo "Failed to disable skel-init.service." >&2
    exit 1
}

if [ "$EUID" -ne 0 ]; then
    sudo systemctl disable skel-init.service || failed
else
    systemctl disable skel-init.service || failed 
fi

echo "Successfully disabled skel-init.service."
exit 0